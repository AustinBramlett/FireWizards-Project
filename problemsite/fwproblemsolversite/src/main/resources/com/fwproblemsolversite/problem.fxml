<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ScrollPane?>

<StackPane prefHeight="700.0" prefWidth="1000.0"
           xmlns="http://javafx.com/javafx/13"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.controllers.ProblemController"
           stylesheets="@styles.css">

    <children>

        <Pane styleClass="background-pane" />

        <ScrollPane fitToWidth="true" styleClass="page-scroll">

            <content>
   
                <AnchorPane>

                   <Button text="Back to Problems"
                           styleClass="back-button"
                           onAction="#handleBackToProblems"
                           AnchorPane.topAnchor="20.0"
                           AnchorPane.leftAnchor="20.0"/>
                    
                    <VBox spacing="40"
                          AnchorPane.topAnchor="80.0"
                          AnchorPane.leftAnchor="80.0"
                          AnchorPane.rightAnchor="80.0">

                <children>

                    <HBox spacing="25">
                        <children>

                    <!-- Left side: Problem details -->
                    <VBox styleClass="problem-container" 
                          HBox.hgrow="ALWAYS" 
                          spacing="24">

                        <children>

                            <Label fx:id="titleLabel" styleClass="problem-title">
                                <font>
                                    <Font size="28" />
                                </font>
                            </Label>

                            <HBox spacing="12">

                                <children>

                                    <Label fx:id="difficultyLabel" text="Easy" styleClass="difficulty-pill" />
                                    <HBox fx:id="tagsBox" spacing="8"/>

                                </children>

                            </HBox>

                            <Label fx:id="descriptionLabel" 
                                   wrapText="true" 
                                   styleClass="problem-description" />

                            <VBox fx:id="examplesBox" spacing="10" />

                        </children>
                    </VBox>

                    <!-- Right side: Code editor and test input -->
                    <VBox styleClass="problem-container" 
                          HBox.hgrow="ALWAYS" 
                          spacing="15">
                                  
                        <children>

                            <Label text="Code" styleClass="section-title" />

                            <TextArea fx:id="codeArea" 
                                      prefHeight="380" 
                                      styleClass="code-area"/>

                            <Label text="Answer" styleClass="section-title" />

                            <TextArea fx:id="answerArea" 
                                      prefHeight="70" 
                                      styleClass="code-area"/>
                                             

                        </children>
                    </VBox>
                </children>
                </HBox>

                <VBox spacing="12">
                
                    <Label text="Comments" styleClass="section-title" />

                    <TextArea fx:id="commentInput" 
                              promptText="Add a comment..."
                              prefHeight="120" 
                              styleClass="code-area"/>

                    <Button text="Submit Comment" 
                            styleClass="submit-button" 
                            onAction="#handleSubmitComment" 
                            alignment="CENTER_RIGHT"/>

                    <VBox fx:id="commentsBox" spacing="10"/>

                </VBox>

            </children>
        </VBox>

           
                   

        </AnchorPane>

    </content>
</ScrollPane>

    </children>
</StackPane>