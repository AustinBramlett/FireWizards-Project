<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextArea?>

<StackPane prefHeight="700.0" prefWidth="1000.0"
           xmlns="http://javafx.com/javafx/13"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.controllers.ProblemController"
           stylesheets="@styles.css">

    <children>

        
        <Pane prefHeight="700.0" prefWidth="1000.0" styleClass="background-pane" />

   
        <AnchorPane>

            <Button text="Back to Problems"
                    styleClass="back-button"
                    onAction="#handleBackToProblems"
                    AnchorPane.topAnchor="20.0"
                    AnchorPane.leftAnchor="20.0"/>
                    
            <HBox spacing="40"
                  AnchorPane.topAnchor="80.0"
                  AnchorPane.bottomAnchor="40.0"
                  AnchorPane.leftAnchor="80.0"
                  AnchorPane.rightAnchor="80.0">

                <children>
                    <!-- Left side: Problem details -->
                    <VBox styleClass="problem-container" 
                          HBox.hgrow="ALWAYS" 
                          spacing="24">

                        <children>

                            <Label fx:id="titleLabel" styleClass="problem-title">
                                <font>
                                    <Font size="28" />
                                </font>
                            </Label>

                            <HBox spacing="12">

                                <children>

                                    <Label fx:id="difficultyLabel" text="Easy" styleClass="difficulty-pill" />
                                    <HBox fx:id="tagsBox" spacing="8"/>

                                </children>

                            </HBox>

                            <Label fx:id="descriptionLabel" 
                                   wrapText="true" 
                                   styleClass="problem-description" />

                            <VBox fx:id="examplesBox" spacing="10" />

                        </children>
                    </VBox>

                    <!-- Right side: Code editor and test input -->
                    <VBox styleClass="problem-container" 
                          HBox.hgrow="ALWAYS" 
                          spacing="24">
                                  
                        <children>

                            <Label text="Code" styleClass="section-title" />

                            <TextArea fx:id="codeArea" 
                                      VBox.vgrow="ALWAYS" 
                                      styleClass="code-area"/>

                            <Label text="Test Input" styleClass="section-title" />

                            <TextArea fx:id="inputArea" 
                                      prefHeight="120" 
                                      styleClass="code-area"/>
                                             

                        </children>
                    </VBox>

                </children>

            </HBox>

        </AnchorPane>
    </children>
</StackPane>