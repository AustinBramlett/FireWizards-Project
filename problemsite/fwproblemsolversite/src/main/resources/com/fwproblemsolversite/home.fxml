<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Hyperlink?>

<StackPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.HomeController" stylesheets="@styles.css">
   <children>
      <Pane prefHeight="600.0" prefWidth="900.0" styleClass="background-pane" />
      
      <AnchorPane prefHeight="600.0" prefWidth="900.0">
         <children>
            <Label text="FWP" styleClass="app-title" AnchorPane.leftAnchor="32.0" AnchorPane.topAnchor="28.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>

            <ImageView fitHeight="28.0" fitWidth="28.0" preserveRatio="true" AnchorPane.leftAnchor="78.0" AnchorPane.topAnchor="27.0">
               <image>
                  <Image url="@images/FireSymbol.png" />
               </image>
            </ImageView>
            
         </children>
      </AnchorPane>

      <VBox fx:id="welcomeBox" alignment="CENTER" maxWidth="460.0" prefWidth="460.0" maxHeight="400.0" prefHeight="400.0" spacing="18.0" styleClass="login-card">

         <children>
            <Label text="Welcome to FWP" styleClass="app-title">
               <font>
                  <Font size="38.0" />
               </font>
            </Label>

            <Label text="Explore and start practicing now" wrapText="true" styleClass="small-text">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>

            <Button fx:id="primaryButton" text="Get Started" onAction="#switchToSecondary" prefWidth="310.0" prefHeight="50.0" styleClass="primary-button" />

            <Button text="Learn More" onAction="#handleLearnMore" prefWidth="310.0" prefHeight="50.0" styleClass="outline-button" />
         </children>

         <padding>
            <Insets top="35.0" right="35.0" bottom="35.0" left="35.0" />
         </padding>
      </VBox>

      <VBox fx:id="readmeBox" visible="false" managed="false" alignment="TOP_LEFT" maxWidth="700.0" prefWidth="700.0" maxHeight="430.0" prefHeight="430.0" spacing="14.0" styleClass="login-card">
         <children>

            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label text="FireWizards" styleClass="app-title">
                     <font>
                        <Font size="30.0" />
                     </font>
                  </Label>

                  <Pane HBox.hgrow="ALWAYS" />

                  <Button text="Back" onAction="#handleBackToWelcome" prefWidth="90.0" styleClass="outline-button" />
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="page-scroll">
               <content>
                  <VBox spacing="12.0">
                     <children>
                        <Label text="Description" styleClass="section-title" />

                        <Label wrapText="true" styleClass="small-text" text="This is a Java problem solving system where users can create their accounts, solve coding problems, and track their progress. The system allows students to view problems based on difficulty and type, submit solutions, and earn achievements as they improve." />

                        <Label text="Links" styleClass="section-title" />

                        <Label text="Demonstration Video:" styleClass="small-text" />

                        <Hyperlink text="https://youtu.be/qUXdicF84K4" styleClass="link-text" onAction="#openDemoVideo" />

                        <Label text="UML Diagram:" styleClass="small-text" />

                        <Hyperlink text="https://lucid.app/lucidchart/590a60f9-f40d-4f81-b1f5-5562af032aed/edit" styleClass="link-text" onAction="#openUML" />

                        <Label text="Features" styleClass="section-title" />

                        <Label text="Create and manage user accounts" styleClass="small-text" />
                        <Label text="Login and logout" styleClass="small-text" />
                        <Label text="View problems by difficulty and type" styleClass="small-text" />
                        <Label text="Submit solutions to problems" styleClass="small-text" />
                        <Label text="Track progress and achievements" styleClass="small-text" />
                        <Label text="Comment on problems" styleClass="small-text" />
                        <Label text="Submit reports" styleClass="small-text" />
                        <Label text="Admins can ban, mute, or remove users and content" styleClass="small-text" />

                        <Label text="User Roles" styleClass="section-title" />

                        <Label text="Student — Solves problems and tracks progress" styleClass="small-text" />
                        <Label text="Contributor — Adds or removes problems" styleClass="small-text" />
                        <Label text="Administrator — Manages users, reports, and problems" styleClass="small-text" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>

         </children>

         <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="25.0" />
         </padding>
      </VBox>

   </children>
</StackPane>