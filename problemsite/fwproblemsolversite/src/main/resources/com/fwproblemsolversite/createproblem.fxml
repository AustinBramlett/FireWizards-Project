<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<StackPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.CreateProblemController" stylesheets="@styles.css">

<children>
    <Pane prefHeight="700.0" prefWidth="1000.0" styleClass="background-pane" />

    <ScrollPane fitToWidth="true" styleClass="page-scroll">
        <content>
            <VBox spacing="14.0" alignment="TOP_CENTER">
                <padding>
                    <Insets top="18.0" right="30.0" bottom="30.0" left="30.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="6.0" maxWidth="780.0">
                    <children>
                        <Label text="FWP" styleClass="app-title" />
                        <ImageView fitHeight="24.0" fitWidth="24.0">
                            <image>
                                <Image url="@images/FireSymbol.png" />
                            </image>
                        </ImageView>
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label/>
                    </children>
                </HBox>

                <VBox spacing="12.0" maxWidth="780.0" styleClass="profile-card">
                    <padding>
                        <Insets top="18.0" right="22.0" bottom="18.0" left="22.0" />
                    </padding>

                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Back to Home Screen" onMouseClicked="#handleBackToDashboard" styleClass="link-text" />
                                <Pane HBox.hgrow="ALWAYS" />

                                <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                                    <children>
                                        <Label text="Create Problem" styleClass="section-title">
                                            <font><Font size="24.0" /></font>
                                        </Label>
                                    </children>
                                </StackPane>

                                <Pane HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <Label text="Title:" styleClass="profile-text" />
                        <TextField fx:id="titleField" promptText="Problem Title..." styleClass="input-field" />

                        <Label text="Description:" styleClass="profile-text" />
                        <TextArea fx:id="descriptionArea"  promptText="Enter your discription here..." prefHeight="130.0" wrapText="true" styleClass="input-area" />

                        <Label text="Summary:" styleClass="profile-text" />
                        <TextField fx:id="summaryField" promptText="Enter summary of your discription here..." styleClass="input-field" />

                        <Label text="Code to Display:" styleClass="profile-text" />
                        <TextArea fx:id="codeArea" promptText="Enter the code users will see..." prefHeight="120.0" wrapText="true" styleClass="input-area" />

                    </children>
                </VBox>

                <VBox spacing="12.0" maxWidth="780.0" styleClass="profile-card">
                    <padding>
                        <Insets top="18.0" right="22.0" bottom="18.0" left="22.0" />
                    </padding>

                    <children>

                        <HBox spacing="14.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Difficulty:" styleClass="profile-text" />
                                <ComboBox fx:id="difficultyBox" prefWidth="130.0" styleClass="input-field">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Easy"/>
                                            <String fx:value="Medium"/>
                                            <String fx:value="Hard"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </children>
                        </HBox>

                        <HBox spacing="10.0">
                            <children>
                                <Label text="Add Tags:" styleClass="profile-text" />
                                <TextField fx:id="tagField" prefWidth="260.0" styleClass="input-field" />
                                <Button text="+" onAction="#handleAddTag" styleClass="primary-button" />
                            </children>
                        </HBox>

                        <HBox fx:id="tagsBox" spacing="8.0" />

                        <HBox spacing="14.0">
                            <children>
                                <Label text="Type:" styleClass="profile-text" />
                                <ComboBox fx:id="typeBox" prefWidth="150.0" styleClass="input-field">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Array"/>
                                            <String fx:value="LinkedList"/>
                                            <String fx:value="Tree"/>
                                            <String fx:value="String"/>
                                            <String fx:value="Stack"/>
                                            <String fx:value="Queue"/>
                                            <String fx:value="Hashmap"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>

                                <Label text="Timer:" styleClass="profile-text" />
                                <ComboBox fx:id="timerBox" prefWidth="120.0" styleClass="input-field">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="None"/>
                                            <String fx:value="5 min"/>
                                            <String fx:value="10 min"/>
                                            <String fx:value="15 min"/>
                                            <String fx:value="30 min"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </children>
                        </HBox>

                        <HBox spacing="10.0">
                            <children>
                                <Label text="Add Constraints:" styleClass="profile-text" />
                                <TextField fx:id="constraintField" prefWidth="300.0" styleClass="input-field" />
                                <Button text="+" onAction="#handleAddConstraint" styleClass="primary-button" />
                            </children>
                        </HBox>

                        <VBox fx:id="constraintsBox" spacing="8.0" />

                        <HBox spacing="10.0">
                            <children>
                                <Label text="Example Outputs:" styleClass="profile-text" />
                                <TextField fx:id="exampleOutputField" prefWidth="300.0" styleClass="input-field" />
                                <Button text="+" onAction="#handleAddExampleOutput" styleClass="primary-button" />
                            </children>
                        </HBox>

                        <VBox fx:id="exampleOutputsBox" spacing="8.0" />

                        <HBox spacing="10.0">
                            <children>
                                <Label text="Add Notes:" styleClass="profile-text" />
                                <TextField fx:id="noteField" prefWidth="300.0" styleClass="input-field" />
                                <Button text="+" onAction="#handleAddNote" styleClass="primary-button" />
                            </children>
                        </HBox>

                        <VBox fx:id="notesBox" spacing="8.0" />

                    </children>
                </VBox>

                <VBox spacing="12.0" maxWidth="780.0" styleClass="profile-card">
                    <padding><Insets top="18" right="22" bottom="18" left="22"/></padding>

                    <children>
                        <Label text="Create Answers" styleClass="section-title">
                            <font><Font size="22"/></font>
                        </Label>
                        <Label text="Answer:" styleClass="profile-text"/>
                        <TextField fx:id="answerTitleField" styleClass="input-field"/>

                        <Button text="Add Answer" onAction="#handleAddAnswer" styleClass="primary-button"/>
                        <VBox fx:id="notesBox" spacing="8.0" />
                    </children>
                    
                </VBox>

                <VBox spacing="12.0" maxWidth="780.0" styleClass="profile-card">
                    <padding><Insets top="18" right="22" bottom="18" left="22"/></padding>

                    <children>
                        
                        <VBox fx:id="answersBox" spacing="8.0"/>

                        <HBox alignment="CENTER" spacing="220.0">
                            <children>
                                <Button text="Cancel Creation" onAction="#handleCancelCreation" styleClass="danger-button"/>

                                <Button text="Create Problem" onAction="#handleCreateProblem" styleClass="success-button"/>
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel" styleClass="error-label"/>
                    </children>
                </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </children>
</StackPane>
