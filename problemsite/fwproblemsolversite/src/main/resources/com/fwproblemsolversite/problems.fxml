<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>

<StackPane prefHeight="700.0" prefWidth="1000.0"
    xmlns="http://javafx.com/javafx/13"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.ProblemsController" stylesheets="@styles.css">

    <children>

        <Pane prefHeight="700.0" prefWidth="1000.0" styleClass="background-pane" />

        <AnchorPane prefHeight="700.0" prefWidth="1000.0">

            <Button text="Back to Dashboard" styleClass="back-button" onAction="#handleBackToDashboard" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"/>

            <Label text="Problems" styleClass="dashboard-title" AnchorPane.topAnchor="40.0" AnchorPane.leftAnchor="80.0">
                <font>
                    <Font size="28.0"/>
                </font>
            </Label>

            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0;" AnchorPane.topAnchor="80.0" AnchorPane.leftAnchor="80.0">

                <TextField fx:id="searchField" promptText="Search Problems..." onKeyReleased="#handleSearch" prefWidth="200"/>

                <Button text="All" styleClass="filter-button" onAction="#handleShowAll"/>
                <Button text="Easy" styleClass="filter-button" onAction="#handleShowEasy"/>
                <Button text="Medium" styleClass="filter-button" onAction="#handleShowMedium"/>
                <Button text="Hard" styleClass="filter-button" onAction="#handleShowHard"/>

            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" AnchorPane.topAnchor="130.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="80.0" AnchorPane.bottomAnchor="20.0" styleClass="page-scroll">

                <content>
                    <VBox fx:id="problemsContainer" spacing="12" style="-fx-padding: 10 10 10 0;">
                        <padding>
                            <Insets top="10"/>
                        </padding>
                    </VBox>
                </content>

            </ScrollPane>
        </AnchorPane>
    </children>
</StackPane>