<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Button?>

<StackPane prefHeight="700.0" prefWidth="1000.0"
           xmlns="http://javafx.com/javafx/13"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.controllers.ProblemsController"
           stylesheets="@styles.css">

    <children>

        <Pane prefHeight="700.0" prefWidth="1000.0" styleClass="background-pane" />

        <AnchorPane prefHeight="700.0" prefWidth="1000.0">

        <Button text="Back to Dashboard"
                styleClass="back-button"
                onAction="#handleBackToDashboard"
                AnchorPane.topAnchor="20.0"
                AnchorPane.leftAnchor="20.0"/>

            <Label text="Problems" styleClass="dashboard-title"
                   AnchorPane.topAnchor="40.0"
                   AnchorPane.leftAnchor="80.0">
                <font>
                    <Font size="28.0"/>
                </font>
            </Label>

            <VBox fx:id="problemsContainer"
                  spacing="12"
                  AnchorPane.topAnchor="100.0"
                  AnchorPane.leftAnchor="80.0"
                  AnchorPane.rightAnchor="80.0">

                <padding>
                    <Insets top="10"/>
                </padding>

            </VBox>

        </AnchorPane>
    </children>
</StackPane>