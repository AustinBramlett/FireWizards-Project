<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.DashboardController" stylesheets="@styles.css">

    <children>

        <Pane prefHeight="600.0" prefWidth="900.0" styleClass="background-pane" />

        <AnchorPane prefHeight="600.0" prefWidth="900.0">
            <children>
                <Label text="FWA" styleClass="app-title" AnchorPane.leftAnchor="32.0" AnchorPane.topAnchor="28.0">
                    <font>
                        <Font size="22.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <VBox alignment="CENTER" spacing="15.0" maxWidth="320.0" prefWidth="320.0" prefHeight="250.0" maxHeight="250.0" styleClass="login-card">

            <children>
                <Label text="Dashboard" styleClass="login-title">
                    <font>
                        <Font size="26.0" />
                    </font>
                </Label>

                <Label fx:id="welcomeLabel" text="Welcome" styleClass="small-text" />

                <Button text="Logout" onAction="#handleLogout" prefWidth="230.0" styleClass="primary-button" />
            </children>

            <padding>
                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
            </padding>
        </VBox>
    </children>
</StackPane>